{
  "meta": {
    "id": "decision_theory",
    "name": "Decision Theory",
    "description": "How to decide things when the parameters are not clear",
    "invariants": [
      "Decision objectives, scope, and the criteria for evaluating success MUST be explicitly defined.",
      "Available alternatives, along with their known or estimated consequences and associated uncertainties, MUST be explicitly identified.",
      "All information inputs, underlying assumptions, and the degree of certainty or uncertainty associated with them MUST be explicitly acknowledged and documented.",
      "The rationale, methodology, and trade-offs employed in reaching a decision MUST be explicit, inspectable, and reconstructible.",
      "The accountable entity for making a decision and for its eventual outcomes MUST be clearly assigned.",
      "Decision outcomes, including anticipated effects and emergent impacts, MUST be observable, measurable, and attributable to the decision.",
      "Mechanisms for ongoing review, feedback, and adaptation based on new information or observed outcomes MUST be established and transparent."
    ],
    "enabled": true,
    "readOnly": false,
    "lastUpdated": "2026-04-11 23:34:51",
    "symbolCount": 24
  },
